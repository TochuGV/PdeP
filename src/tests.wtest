import entidades.nivel.*;
import entidades.puntaje.*
import entidades.cuadradoEstatico.*
import wollok.game.*

describe "Niveles" {
  test "Hay dos pistas" {
    const nivel = new Nivel(
      colores = ["azul.jpg", "rojo.jpg"],
      velocidadDeGeneracion = 500,
      velocidadDeMovimiento = 200,
      cantidadDeCoincidenciasParaGanar = 5
    )
    nivel.iniciar()
    assert.equals(2, nivel.pistas().size())
  }
}

describe "Puntos" {
  test "Se suman puntos" {
    puntaje.sumarPuntos(100)
    assert.equals(100, puntaje.puntos())
  }
}

