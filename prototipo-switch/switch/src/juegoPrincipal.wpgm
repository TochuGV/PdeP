import wollok.game.*
import juego.*

program juegoPrincipal {
game.width(30);
game.height(6);
game.title('Switch! - Prototipo')
juego.iniciar();
game.start();

// Eventos de teclado
keyboard.s().onPressDo{juego.intercambiarColores()};
keyboard.a().onPressDo{juego.cambiarModo()};
 


}